{
  "name": "@oharato/pdf2md-ts",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/oharato/pdf2md-ts.git" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "description": "Hybrid raycasting + vector-graph PDF table to Markdown converter",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src tests vite.config.ts --deny-warnings",
    "cli": "node --enable-source-maps dist/cli.js",
    "diag:ops": "tsx scripts/dump-operators.ts",
    "diag:segs": "tsx scripts/dump-segments.ts"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38",
    "rbush": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "latest",
    "oxlint": "^0.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  }
}